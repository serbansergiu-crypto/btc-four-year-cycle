<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bitcoin 4-Year Cycle Analysis</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #21262d;
  --border: #30363d;
  --text: #e6edf3;
  --muted: #8b949e;
  --btc: #f7931a;
  --btc2: #ffb347;
  --green: #3fb950;
  --red: #f85149;
  --purple: #a371f7;
  --teal: #58a6ff;
  --gold: #d29922;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:'Space Grotesk',sans-serif; line-height:1.6; }

/* NAV */
nav { background:var(--surface); border-bottom:1px solid var(--border); padding:0 32px; display:flex; align-items:center; gap:8px; overflow-x:auto; position:sticky; top:0; z-index:100; }
.nav-brand { font-family:'Space Mono',monospace; font-size:13px; color:var(--btc); font-weight:700; padding:16px 0; margin-right:16px; white-space:nowrap; }
.nav-tab { font-size:12px; padding:16px 14px; cursor:pointer; color:var(--muted); border-bottom:2px solid transparent; transition:all .2s; white-space:nowrap; }
.nav-tab:hover { color:var(--text); }
.nav-tab.active { color:var(--btc); border-bottom-color:var(--btc); }

/* HERO */
.hero { background:linear-gradient(135deg,#0d1117 0%,#1a0a00 50%,#0d1117 100%); padding:56px 32px; text-align:center; border-bottom:1px solid var(--border); position:relative; overflow:hidden; }
.hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 50% 0%,rgba(247,147,26,0.08) 0%,transparent 70%); }
.hero-tag { font-family:'Space Mono',monospace; font-size:10px; letter-spacing:3px; text-transform:uppercase; color:var(--btc); margin-bottom:16px; }
.hero h1 { font-size:clamp(28px,5vw,52px); font-weight:700; letter-spacing:-1px; margin-bottom:12px; }
.hero h1 span { color:var(--btc); }
.hero-sub { font-size:15px; color:var(--muted); max-width:560px; margin:0 auto 28px; }
.hero-badges { display:flex; gap:8px; justify-content:center; flex-wrap:wrap; }
.badge { font-family:'Space Mono',monospace; font-size:10px; padding:4px 12px; border-radius:20px; border:1px solid; }
.badge-btc { color:var(--btc); border-color:rgba(247,147,26,0.3); background:rgba(247,147,26,0.08); }
.badge-green { color:var(--green); border-color:rgba(63,185,80,0.3); background:rgba(63,185,80,0.08); }
.badge-blue { color:var(--teal); border-color:rgba(88,166,255,0.3); background:rgba(88,166,255,0.08); }

/* LAYOUT */
.container { max-width:1200px; margin:0 auto; padding:0 32px; }
.section { padding:40px 0; border-bottom:1px solid var(--border); }
.section:last-child { border-bottom:none; }
.section-title { font-size:18px; font-weight:600; margin-bottom:6px; }
.section-sub { font-size:13px; color:var(--muted); margin-bottom:24px; }

/* KPI CARDS */
.kpi-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:12px; margin-bottom:32px; }
.kpi-card { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:20px; position:relative; overflow:hidden; }
.kpi-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; }
.kpi-btc::before { background:var(--btc); }
.kpi-green::before { background:var(--green); }
.kpi-red::before { background:var(--red); }
.kpi-purple::before { background:var(--purple); }
.kpi-teal::before { background:var(--teal); }
.kpi-label { font-family:'Space Mono',monospace; font-size:9px; letter-spacing:2px; text-transform:uppercase; color:var(--muted); margin-bottom:8px; }
.kpi-value { font-size:24px; font-weight:700; margin-bottom:4px; }
.kpi-sub { font-size:11px; color:var(--muted); }

/* CHARTS */
.chart-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.chart-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; }
.chart-card { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:20px; }
.chart-title { font-size:13px; font-weight:600; margin-bottom:4px; }
.chart-sub { font-size:11px; color:var(--muted); margin-bottom:16px; }

/* TABLES */
.table-wrap { overflow-x:auto; margin-top:16px; }
table { width:100%; border-collapse:collapse; font-size:12px; }
th { background:var(--surface2); padding:10px 12px; text-align:center; font-family:'Space Mono',monospace; font-size:9px; letter-spacing:1px; text-transform:uppercase; color:var(--muted); border:1px solid var(--border); white-space:nowrap; }
td { padding:10px 12px; border:1px solid var(--border); text-align:center; }
tr:nth-child(even) td { background:rgba(255,255,255,0.02); }
tr:hover td { background:rgba(247,147,26,0.04); }
.td-green { color:var(--green); font-weight:600; }
.td-red { color:var(--red); font-weight:600; }
.td-btc { color:var(--btc); font-weight:600; }
.td-left { text-align:left; }
.td-bold { font-weight:600; }

/* CYCLE TIMELINE */
.timeline { position:relative; padding:20px 0; }
.tl-line { position:absolute; left:120px; top:0; bottom:0; width:2px; background:var(--border); }
.tl-item { display:flex; align-items:flex-start; gap:20px; margin-bottom:24px; position:relative; }
.tl-date { width:100px; text-align:right; font-family:'Space Mono',monospace; font-size:10px; color:var(--muted); padding-top:4px; flex-shrink:0; }
.tl-dot { width:12px; height:12px; border-radius:50%; border:2px solid; flex-shrink:0; margin-top:4px; position:relative; z-index:1; }
.tl-content { flex:1; }
.tl-title { font-size:13px; font-weight:600; margin-bottom:2px; }
.tl-desc { font-size:12px; color:var(--muted); }
.tl-stats { display:flex; gap:12px; margin-top:6px; flex-wrap:wrap; }
.tl-stat { font-family:'Space Mono',monospace; font-size:10px; padding:2px 8px; border-radius:4px; }

/* INSIGHT BOXES */
.insight-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:16px; margin-top:20px; }
.insight { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:20px; border-left:3px solid; }
.insight-holds { border-left-color:var(--green); }
.insight-evolving { border-left-color:var(--gold); }
.insight-uncertain { border-left-color:var(--red); }
.insight-tag { font-family:'Space Mono',monospace; font-size:9px; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px; }
.insight-holds .insight-tag { color:var(--green); }
.insight-evolving .insight-tag { color:var(--gold); }
.insight-uncertain .insight-tag { color:var(--red); }
.insight-title { font-size:13px; font-weight:600; margin-bottom:6px; }
.insight-body { font-size:12px; color:var(--muted); line-height:1.6; }

/* PAGE VIEWS */
.page { display:none; }
.page.active { display:block; }

@media (max-width:768px) {
  .chart-grid, .chart-grid-3 { grid-template-columns:1fr; }
  .container { padding:0 16px; }
  .tl-line { left:80px; }
  .tl-date { width:68px; font-size:9px; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-brand">₿ BTC 4Y CYCLE</div>
  <div class="nav-tab active" onclick="showPage('overview',this)">Overview</div>
  <div class="nav-tab" onclick="showPage('halvings',this)">Halvings</div>
  <div class="nav-tab" onclick="showPage('phases',this)">Cycle Phases</div>
  <div class="nav-tab" onclick="showPage('drawdowns',this)">Peaks & Drawdowns</div>
  <div class="nav-tab" onclick="showPage('altcoins',this)">Altcoin Rotation</div>
  <div class="nav-tab" onclick="showPage('cycle4',this)">Cycle 4 Now</div>
</nav>

<!-- ══════════════ HERO ══════════════ -->
<div class="hero">
  <div class="hero-tag">Bitcoin Four-Year Cycle Analysis · All 4 Cycles · 2012–Present</div>
  <h1>The <span>Bitcoin</span> Four-Year<br>Cycle Is Not Dead</h1>
  <p class="hero-sub">A data-driven breakdown of every halving, cycle peak, bear market, and altcoin rotation since 2012 — including where we stand in Cycle 4.</p>
  <div class="hero-badges">
    <span class="badge badge-btc">4 Halvings Analyzed</span>
    <span class="badge badge-green">Cycle 4 ATH: $126,296</span>
    <span class="badge badge-blue">Oct 2025 Peak @ 534d Post-Halving</span>
    <span class="badge badge-btc">ETF Era Dynamics</span>
    <span class="badge badge-green">Next Halving: ~Apr 2028</span>
  </div>
</div>

<!-- ══════════════ OVERVIEW PAGE ══════════════ -->
<div id="overview" class="page active">
<div class="container">

  <div class="section">
    <div class="kpi-grid">
      <div class="kpi-card kpi-btc">
        <div class="kpi-label">Cycle 4 ATH</div>
        <div class="kpi-value" style="color:var(--btc)">$126,296</div>
        <div class="kpi-sub">Oct 6, 2025 · 534 days post-halving</div>
      </div>
      <div class="kpi-card kpi-green">
        <div class="kpi-label">Cycle 4 ROI (from bottom)</div>
        <div class="kpi-value" style="color:var(--green)">+716%</div>
        <div class="kpi-sub">$15,476 → $126,296</div>
      </div>
      <div class="kpi-card kpi-red">
        <div class="kpi-label">Current ATH Drawdown</div>
        <div class="kpi-value" style="color:var(--red)">−46.7%</div>
        <div class="kpi-sub">~$67,550 as of Feb 2026</div>
      </div>
      <div class="kpi-card kpi-teal">
        <div class="kpi-label">4th Halving</div>
        <div class="kpi-value" style="color:var(--teal)">Apr 20, 2024</div>
        <div class="kpi-sub">Block reward: 6.25 → 3.125 BTC</div>
      </div>
      <div class="kpi-card kpi-purple">
        <div class="kpi-label">5th Halving (Est.)</div>
        <div class="kpi-value" style="color:var(--purple)">~Apr 2028</div>
        <div class="kpi-sub">Reward: 3.125 → 1.5625 BTC</div>
      </div>
    </div>

    <div class="chart-grid">
      <div class="chart-card" style="grid-column:1/-1">
        <div class="chart-title">Bitcoin Cycle Returns — Post-Halving Gains (Diminishing but Significant)</div>
        <div class="chart-sub">% gain from halving price to cycle ATH, each cycle</div>
        <canvas id="returnsChart" height="80"></canvas>
      </div>
    </div>

    <div class="chart-grid" style="margin-top:20px">
      <div class="chart-card">
        <div class="chart-title">Bear Market Drawdowns by Cycle</div>
        <div class="chart-sub">Max % decline from ATH — shrinking each cycle</div>
        <canvas id="drawdownChart" height="200"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-title">Days from Halving to Cycle ATH</div>
        <div class="chart-sub">Historically consistent 365–546 day window</div>
        <canvas id="daysChart" height="200"></canvas>
      </div>
    </div>
  </div>

</div>
</div>

<!-- ══════════════ HALVINGS PAGE ══════════════ -->
<div id="halvings" class="page">
<div class="container">
  <div class="section">
    <div class="section-title">Halving Events — Supply Shock History</div>
    <div class="section-sub">Every ~210,000 blocks (~4 years), Bitcoin's block reward is cut in half. This reduces new supply entering circulation and has historically preceded major bull runs.</div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Halving #</th><th>Date</th><th>Block</th><th>Reward Before</th><th>Reward After</th>
            <th>Price at Halving</th><th>Cycle ATH</th><th>Gain Halving→ATH</th><th>Days to ATH</th><th>Supply Inflation After</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="td-btc td-bold">1st</td><td>Nov 28, 2012</td><td>210,000</td>
            <td>50 BTC</td><td>25 BTC</td><td>$12.35</td>
            <td class="td-green">$1,150</td><td class="td-green">+9,213%</td><td>367</td><td>~12%/yr</td>
          </tr>
          <tr>
            <td class="td-btc td-bold">2nd</td><td>Jul 9, 2016</td><td>420,000</td>
            <td>25 BTC</td><td>12.5 BTC</td><td>$650.63</td>
            <td class="td-green">$19,891</td><td class="td-green">+2,960%</td><td>525</td><td>~4%/yr</td>
          </tr>
          <tr>
            <td class="td-btc td-bold">3rd</td><td>May 11, 2020</td><td>630,000</td>
            <td>12.5 BTC</td><td>6.25 BTC</td><td>$8,821</td>
            <td class="td-green">$68,789</td><td class="td-green">+680%</td><td>546</td><td>~1.8%/yr</td>
          </tr>
          <tr>
            <td class="td-btc td-bold">4th</td><td>Apr 20, 2024</td><td>840,000</td>
            <td>6.25 BTC</td><td>3.125 BTC</td><td>$63,850</td>
            <td class="td-green">$126,296</td><td class="td-green">+98%</td><td>534</td><td>~0.85%/yr</td>
          </tr>
          <tr style="background:rgba(247,147,26,0.05)">
            <td class="td-btc td-bold">5th*</td><td>~Apr 2028</td><td>~1,050,000</td>
            <td>3.125 BTC</td><td>1.5625 BTC</td><td>TBD</td>
            <td>TBD</td><td>TBD</td><td>TBD</td><td>~0.4%/yr</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="chart-card" style="margin-top:24px">
      <div class="chart-title">Post-Halving Price Performance — 365 Days After Each Halving</div>
      <div class="chart-sub">Indexed to $100 at halving date for each cycle</div>
      <canvas id="postHalvingChart" height="100"></canvas>
    </div>
  </div>
</div>
</div>

<!-- ══════════════ CYCLE PHASES PAGE ══════════════ -->
<div id="phases" class="page">
<div class="container">
  <div class="section">
    <div class="section-title">The Four-Phase Cycle Model</div>
    <div class="section-sub">Every Bitcoin cycle follows a consistent 4-phase structure: Accumulation → Bull Run → Bear Market → Recovery. The timing shifts but the pattern holds.</div>

    <div class="chart-grid" style="margin-bottom:24px">
      <div class="chart-card">
        <div class="chart-title">Bull Run Duration (Days Post-Halving)</div>
        <div class="chart-sub">How long each post-halving bull market lasted</div>
        <canvas id="bullDurationChart" height="220"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-title">Bear Market Duration (Days from ATH to Bottom)</div>
        <div class="chart-sub">How long each crash lasted before bottoming</div>
        <canvas id="bearDurationChart" height="220"></canvas>
      </div>
    </div>

    <div class="section-title" style="margin-bottom:16px">Cycle Timeline</div>
    <div class="timeline">
      <div class="tl-line"></div>
      <!-- Cycle 1 -->
      <div class="tl-item">
        <div class="tl-date">Nov 2012</div>
        <div class="tl-dot" style="background:var(--btc);border-color:var(--btc)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--btc)">1st Halving — 50→25 BTC/block</div>
          <div class="tl-desc">Price: $12.35. Supply growth cut from 25% to 12% annual inflation.</div>
          <div class="tl-stats">
            <span class="tl-stat" style="background:rgba(63,185,80,0.1);color:var(--green)">Bull: +9,213% over 367d</span>
            <span class="tl-stat" style="background:rgba(248,81,73,0.1);color:var(--red)">Bear: −85% over 409d</span>
          </div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Nov 2013</div>
        <div class="tl-dot" style="background:var(--green);border-color:var(--green)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--green)">Cycle 1 ATH — $1,150</div>
          <div class="tl-desc">First major mainstream moment. China's interest drove parabolic move before PBoC ban triggered crash.</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Jan 2015</div>
        <div class="tl-dot" style="background:var(--red);border-color:var(--red)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--red)">Cycle 1 Bottom — $170</div>
          <div class="tl-desc">Mt. Gox collapsed Feb 2014. −85% drawdown. Bitcoin declared "dead" 50+ times.</div>
        </div>
      </div>
      <!-- Cycle 2 -->
      <div class="tl-item">
        <div class="tl-date">Jul 2016</div>
        <div class="tl-dot" style="background:var(--btc);border-color:var(--btc)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--btc)">2nd Halving — 25→12.5 BTC/block</div>
          <div class="tl-desc">Price: $650. Annual supply inflation drops to ~4%. ETH/ICO era begins.</div>
          <div class="tl-stats">
            <span class="tl-stat" style="background:rgba(63,185,80,0.1);color:var(--green)">Bull: +2,960% over 525d</span>
            <span class="tl-stat" style="background:rgba(248,81,73,0.1);color:var(--red)">Bear: −84% over 363d</span>
          </div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Dec 2017</div>
        <div class="tl-dot" style="background:var(--green);border-color:var(--green)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--green)">Cycle 2 ATH — $19,891</div>
          <div class="tl-desc">ICO mania, futures launch. First major altseason — ETH hit $1,400, XRP +63,900%. CME futures preceded the top.</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Dec 2018</div>
        <div class="tl-dot" style="background:var(--red);border-color:var(--red)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--red)">Cycle 2 Bottom — $3,122</div>
          <div class="tl-desc">Regulatory crackdown on ICOs. −84% drawdown. Most ICO projects went to zero.</div>
        </div>
      </div>
      <!-- Cycle 3 -->
      <div class="tl-item">
        <div class="tl-date">May 2020</div>
        <div class="tl-dot" style="background:var(--btc);border-color:var(--btc)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--btc)">3rd Halving — 12.5→6.25 BTC/block</div>
          <div class="tl-desc">Price: $8,821. COVID backdrop. Supply inflation drops to ~1.8%. MicroStrategy/Tesla institutional buys incoming.</div>
          <div class="tl-stats">
            <span class="tl-stat" style="background:rgba(63,185,80,0.1);color:var(--green)">Bull: +680% over 546d</span>
            <span class="tl-stat" style="background:rgba(248,81,73,0.1);color:var(--red)">Bear: −77% over 376d</span>
          </div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Nov 2021</div>
        <div class="tl-dot" style="background:var(--green);border-color:var(--green)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--green)">Cycle 3 ATH — $68,789</div>
          <div class="tl-desc">Double-top structure. DeFi + NFT mania. SOL reached $260. Fed began signalling rate hikes — cycle topped.</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Nov 2022</div>
        <div class="tl-dot" style="background:var(--red);border-color:var(--red)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--red)">Cycle 3 Bottom — $15,476</div>
          <div class="tl-desc">Luna collapse (May 2022) + FTX collapse (Nov 2022). −77.5% — smallest bear drawdown yet. Fed hikes peaked.</div>
        </div>
      </div>
      <!-- Cycle 4 -->
      <div class="tl-item">
        <div class="tl-date">Apr 2024</div>
        <div class="tl-dot" style="background:var(--btc);border-color:var(--btc)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--btc)">4th Halving — 6.25→3.125 BTC/block ⚡ ETF ERA</div>
          <div class="tl-desc">Price: $63,850. Bitcoin ETFs launched Jan 2024 — drove pre-halving ATH of $73,750 in March (FIRST TIME EVER a new high came before halving).</div>
          <div class="tl-stats">
            <span class="tl-stat" style="background:rgba(63,185,80,0.1);color:var(--green)">Bull: +98% over 534d</span>
            <span class="tl-stat" style="background:rgba(248,81,73,0.1);color:var(--red)">Current drawdown: −46.7%</span>
          </div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Oct 2025</div>
        <div class="tl-dot" style="background:var(--green);border-color:var(--green)"></div>
        <div class="tl-content">
          <div class="tl-title" style="color:var(--green)">Cycle 4 ATH — $126,296 ✓ Fits Pattern</div>
          <div class="tl-desc">534 days post-halving — right in the 365–546 day historical window. ETF-driven, more gradual, less parabolic than prior cycles.</div>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date">Feb 2026</div>
        <div class="tl-dot" style="background:var(--muted);border-color:var(--muted)"></div>
        <div class="tl-content">
          <div class="tl-title">Current Status — ~$67,550 (Bear Not Confirmed)</div>
          <div class="tl-desc">−46.7% from ATH. Historical pattern would project a bottom late 2026. Projected range: $34K–$63K depending on severity.</div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- ══════════════ DRAWDOWNS PAGE ══════════════ -->
<div id="drawdowns" class="page">
<div class="container">
  <div class="section">
    <div class="section-title">Cycle Peaks, Bear Markets & Drawdowns</div>
    <div class="section-sub">Bitcoin bear markets get less severe each cycle — but still occur. The floor is rising as institutional capital provides structural support.</div>

    <div class="table-wrap">
      <table>
        <thead><tr>
          <th>Cycle</th><th>ATH Date</th><th>ATH Price</th><th>Bear Bottom</th><th>Bottom Price</th>
          <th>Max Drawdown</th><th>Bear Duration</th><th>Trigger</th>
        </tr></thead>
        <tbody>
          <tr><td class="td-bold">1</td><td>Nov 30, 2013</td><td class="td-green">$1,150</td><td>Jan 14, 2015</td><td class="td-red">$170</td><td class="td-red">−85.2%</td><td>409 days</td><td class="td-left">Mt. Gox collapse; China BTC ban</td></tr>
          <tr><td class="td-bold">2</td><td>Dec 17, 2017</td><td class="td-green">$19,891</td><td>Dec 15, 2018</td><td class="td-red">$3,122</td><td class="td-red">−84.3%</td><td>363 days</td><td class="td-left">ICO bubble burst; regulatory crackdown</td></tr>
          <tr><td class="td-bold">3</td><td>Nov 10, 2021</td><td class="td-green">$68,789</td><td>Nov 21, 2022</td><td class="td-red">$15,476</td><td class="td-red">−77.5%</td><td>376 days</td><td class="td-left">Fed rate hikes; Luna + FTX collapses</td></tr>
          <tr><td class="td-bold">4*</td><td>Oct 6, 2025</td><td class="td-green">$126,296</td><td>Ongoing</td><td>TBD</td><td class="td-red">−46.7%*</td><td>~146d+</td><td class="td-left">Macro uncertainty; post-ATH distribution</td></tr>
        </tbody>
      </table>
    </div>

    <div class="chart-grid" style="margin-top:24px">
      <div class="chart-card">
        <div class="chart-title">Bear Market Severity — Improving Each Cycle</div>
        <div class="chart-sub">Max drawdown % from ATH — clear downward trend</div>
        <canvas id="bearSeverityChart" height="220"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-title">Projected Bottom Range — Cycle 4</div>
        <div class="chart-sub">Based on historical drawdown % applied to $126,296 ATH</div>
        <canvas id="projectionChart" height="220"></canvas>
      </div>
    </div>

    <div class="insight-grid" style="margin-top:24px">
      <div class="insight insight-holds">
        <div class="insight-tag">✅ Pattern Holds</div>
        <div class="insight-title">Drawdowns Are Shrinking</div>
        <div class="insight-body">−93% (2011) → −85% (2015) → −84% (2018) → −77% (2022). Each cycle, the bear market is less severe. Extrapolating suggests the Cycle 4 bear bottom may be −70% to −76%, implying $30K–$38K if confirmed.</div>
      </div>
      <div class="insight insight-evolving">
        <div class="insight-tag">⚠️ Evolving Dynamic</div>
        <div class="insight-title">ETF Floor Effect</div>
        <div class="insight-body">BlackRock's IBIT alone holds $72.8B+ in BTC. Institutional ETF holders have multi-year time horizons. This creates a "soft floor" — unlike retail panic-sellers of previous cycles. Current −46.7% may be as bad as it gets.</div>
      </div>
      <div class="insight insight-holds">
        <div class="insight-tag">✅ Historically Consistent</div>
        <div class="insight-title">Bear Duration ~12 Months</div>
        <div class="insight-body">Cycles 1, 2, and 3 all bottomed within 363–409 days of the ATH. If Cycle 4's ATH was Oct 2025, historical patterns project a bottom around late 2026 — aligning with the pre-2028 halving accumulation phase.</div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- ══════════════ ALTCOINS PAGE ══════════════ -->
<div id="altcoins" class="page">
<div class="container">
  <div class="section">
    <div class="section-title">Altcoin Rotation & BTC Dominance Cycles</div>
    <div class="section-sub">Capital flows from Bitcoin into altcoins in a consistent rotation pattern — though Cycle 4's ETF dynamics have changed the timing and selectivity of altseasons.</div>

    <div class="chart-card" style="margin-bottom:24px">
      <div class="chart-title">BTC Dominance Cycle — How Capital Rotates</div>
      <div class="chart-sub">BTC dominance % through each major cycle phase</div>
      <canvas id="dominanceChart" height="90"></canvas>
    </div>

    <div class="section-title" style="margin:24px 0 8px">Altcoin Performance vs BTC — Cycle 3 (2020–2021)</div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Asset</th><th>Start Price</th><th>Cycle Peak</th><th>% Gain</th><th>vs BTC (+680%)</th><th>Notes</th></tr></thead>
        <tbody>
          <tr><td class="td-btc td-bold">BTC</td><td>$8,821</td><td>$68,789</td><td class="td-green">+680%</td><td>—</td><td class="td-left">Baseline</td></tr>
          <tr><td class="td-bold">ETH</td><td>$185</td><td>$4,868</td><td class="td-green">+2,532%</td><td class="td-green">+3.7× BTC</td><td class="td-left">DeFi summer + ETH2 hype</td></tr>
          <tr><td class="td-bold">SOL</td><td>$0.77</td><td>$260</td><td class="td-green">+33,666%</td><td class="td-green">+49.5× BTC</td><td class="td-left">Best performer of the cycle</td></tr>
          <tr><td class="td-bold">BNB</td><td>$14</td><td>$688</td><td class="td-green">+4,814%</td><td class="td-green">+7.1× BTC</td><td class="td-left">BSC DeFi ecosystem</td></tr>
          <tr><td class="td-bold">ADA</td><td>$0.03</td><td>$3.10</td><td class="td-green">+10,233%</td><td class="td-green">+15.1× BTC</td><td class="td-left">Smart contract hype</td></tr>
          <tr><td class="td-bold">DOGE</td><td>$0.002</td><td>$0.74</td><td class="td-green">+36,900%</td><td class="td-green">+54.3× BTC</td><td class="td-left">Elon Musk catalyst</td></tr>
        </tbody>
      </table>
    </div>

    <div class="section-title" style="margin:24px 0 8px">Altcoin Performance vs BTC — Cycle 4 (2022–2025, ETF Era)</div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Asset</th><th>Cycle Low</th><th>Cycle Peak</th><th>% Gain</th><th>vs BTC (+716%)</th><th>ETF Era Notes</th></tr></thead>
        <tbody>
          <tr><td class="td-btc td-bold">BTC</td><td>$15,476</td><td>$126,296</td><td class="td-green">+716%</td><td>—</td><td class="td-left">Baseline — ETF inflows drove dominance to 61%</td></tr>
          <tr><td class="td-bold">ETH</td><td>$880</td><td>$4,100</td><td class="td-green">+366%</td><td class="td-red">−0.5× BTC</td><td class="td-left">Underperformed vs. history; ETH/BTC ratio fell</td></tr>
          <tr><td class="td-bold">SOL</td><td>$8</td><td>$294</td><td class="td-green">+3,575%</td><td class="td-green">+5.0× BTC</td><td class="td-left">FTX narrative recovery; high-throughput dominance</td></tr>
          <tr><td class="td-bold">BNB</td><td>$210</td><td>$999</td><td class="td-green">+376%</td><td class="td-red">~matched</td><td class="td-left">Exchange token; regulatory risk priced in</td></tr>
          <tr><td class="td-bold">XRP</td><td>$0.30</td><td>$3.40</td><td class="td-green">+1,033%</td><td class="td-green">+1.4× BTC</td><td class="td-left">SEC case resolution + payment adoption narrative</td></tr>
          <tr><td class="td-bold">DOGE</td><td>$0.07</td><td>$0.48</td><td class="td-green">+586%</td><td class="td-red">~matched</td><td class="td-left">Trump/Musk catalysts; DOGE government role</td></tr>
        </tbody>
      </table>
    </div>

    <div class="insight-grid" style="margin-top:24px">
      <div class="insight insight-holds">
        <div class="insight-tag">✅ Consistent Pattern</div>
        <div class="insight-title">Altseason Still Happens — Just Later & More Selective</div>
        <div class="insight-body">In 2017, altseason followed BTC ATH by 1–2 months. In 2021, altseason ran alongside BTC's second leg. In Cycle 4, the full altseason has been delayed — analysts expect 2026 for the broadest rotation.</div>
      </div>
      <div class="insight insight-evolving">
        <div class="insight-tag">⚠️ Cycle 4 Difference</div>
        <div class="insight-title">ETH Underperformed — First Time</div>
        <div class="insight-body">Ethereum historically multiplied 3–10× faster than BTC each cycle. In Cycle 4, ETH underperformed BTC for the first time. ETH/BTC ratio hit multi-year lows. SOL, XRP, and niche alts took ETH's former role.</div>
      </div>
      <div class="insight insight-uncertain">
        <div class="insight-tag">📊 Data Point</div>
        <div class="insight-title">BTC Dominance Floor is Higher Now</div>
        <div class="insight-body">In 2021, BTC dominance crashed to 38%. In Cycle 4, the lowest reached ~55%. Institutional ETF holders don't rotate into alts — they hold BTC. The "universal altseason" of the past may not return to the same depth.</div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- ══════════════ CYCLE 4 PAGE ══════════════ -->
<div id="cycle4" class="page">
<div class="container">
  <div class="section">
    <div class="section-title">Cycle 4 — Where Are We Now? (March 2026)</div>
    <div class="section-sub">The 4th halving cycle has confirmed the pattern holds — but with important structural differences driven by ETF adoption and institutional capital.</div>

    <div class="kpi-grid">
      <div class="kpi-card kpi-btc">
        <div class="kpi-label">4th Halving</div>
        <div class="kpi-value" style="color:var(--btc);font-size:16px">Apr 20, 2024</div>
        <div class="kpi-sub">6.25 → 3.125 BTC/block</div>
      </div>
      <div class="kpi-card kpi-teal">
        <div class="kpi-label">Pre-Halving ATH (Unprecedented)</div>
        <div class="kpi-value" style="color:var(--teal);font-size:16px">$73,750</div>
        <div class="kpi-sub">Mar 14, 2024 — BEFORE halving</div>
      </div>
      <div class="kpi-card kpi-green">
        <div class="kpi-label">Cycle 4 ATH</div>
        <div class="kpi-value" style="color:var(--green);font-size:16px">$126,296</div>
        <div class="kpi-sub">Oct 6, 2025 — 534d post-halving ✓</div>
      </div>
      <div class="kpi-card kpi-red">
        <div class="kpi-label">Current Price (Feb 2026)</div>
        <div class="kpi-value" style="color:var(--red);font-size:16px">~$67,550</div>
        <div class="kpi-sub">−46.7% from ATH — bear not confirmed</div>
      </div>
    </div>

    <div class="section-title" style="margin:24px 0 8px">Is the 4-Year Cycle Dead? Evidence Review</div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Verdict</th><th>Argument</th><th>Data</th></tr></thead>
        <tbody>
          <tr>
            <td style="color:var(--green);font-weight:700;white-space:nowrap">✅ HOLDS</td>
            <td class="td-left">Cycle 4 ATH at 534 days post-halving</td>
            <td class="td-left">Historical window: 365–546 days. Perfectly on schedule.</td>
          </tr>
          <tr>
            <td style="color:var(--green);font-weight:700;white-space:nowrap">✅ HOLDS</td>
            <td class="td-left">Bear market drawdowns shrinking but occurring</td>
            <td class="td-left">−93%→−85%→−84%→−77% trend; −46.7% ongoing fits the curve</td>
          </tr>
          <tr>
            <td style="color:var(--green);font-weight:700;white-space:nowrap">✅ HOLDS</td>
            <td class="td-left">Altseason still happens — delayed & selective</td>
            <td class="td-left">SOL +3,575%, XRP +1,033%. Capital rotation occurred.</td>
          </tr>
          <tr>
            <td style="color:var(--gold);font-weight:700;white-space:nowrap">⚠️ EVOLVING</td>
            <td class="td-left">ETFs caused pre-halving ATH — never seen before</td>
            <td class="td-left">$73,750 on Mar 14, 2024 — before the Apr 2024 halving</td>
          </tr>
          <tr>
            <td style="color:var(--gold);font-weight:700;white-space:nowrap">⚠️ EVOLVING</td>
            <td class="td-left">Post-halving returns much smaller (+98% vs +680%+)</td>
            <td class="td-left">Diminishing returns every cycle as supply shock weakens</td>
          </tr>
          <tr>
            <td style="color:var(--gold);font-weight:700;white-space:nowrap">⚠️ EVOLVING</td>
            <td class="td-left">ETF institutional floor limits downside</td>
            <td class="td-left">BlackRock IBIT: $72.8B+ — sticky capital unlike retail</td>
          </tr>
          <tr>
            <td style="color:var(--red);font-weight:700;white-space:nowrap">❓ UNCERTAIN</td>
            <td class="td-left">RSI never reached 90+ this cycle (historically signals top)</td>
            <td class="td-left">Monthly RSI peaked ~65–70 vs 90+ in 2013, 2017, 2021</td>
          </tr>
          <tr>
            <td style="color:var(--red);font-weight:700;white-space:nowrap">❓ UNCERTAIN</td>
            <td class="td-left">Could this be a mid-cycle correction, not the ATH?</td>
            <td class="td-left">Some analysts see $126K as interim top; extended cycle to 2026</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="insight-grid" style="margin-top:24px">
      <div class="insight insight-holds">
        <div class="insight-tag">✅ Bottom Line</div>
        <div class="insight-title">The Cycle Holds — But It's Maturing</div>
        <div class="insight-body">The 4-year cycle framework remains the most reliable tool for long-horizon Bitcoin analysis. Cycle 4 confirmed the timing (534 days), confirmed the altcoin rotation, and confirmed diminishing-but-significant returns. What's changing is the <em>shape</em> — less parabolic, less retail-driven, slower ascent, softer drawdowns.</div>
      </div>
      <div class="insight insight-evolving">
        <div class="insight-tag">⚠️ Watch For</div>
        <div class="insight-title">2026 Bear vs Extended Bull</div>
        <div class="insight-body">Two scenarios: (1) Bear confirmed — historical patterns suggest bottom late 2026 at $34K–$63K range, then recovery into 2028 halving. (2) Extended cycle — $126K was a mid-cycle top; macro tailwinds (Fed cuts, Trump pro-crypto policy) extend bull into 2026 for a higher ATH. The RSI and ETF flow data support either case.</div>
      </div>
      <div class="insight insight-holds">
        <div class="insight-tag">📅 Key Dates Ahead</div>
        <div class="insight-title">Looking Toward Cycle 5</div>
        <div class="insight-body">5th Halving: ~April 2028 (reward: 1.5625 BTC/block). By then &lt;5% of all BTC left to mine. Expected Cycle 5 bull: 2028–2029. Supply inflation will be ~0.4% — below gold's annual mining growth. The scarcity argument only gets stronger.</div>
      </div>
    </div>
  </div>
</div>
</div>

<script>
const btcOrange = '#f7931a';
const btcOrange2 = 'rgba(247,147,26,0.15)';
const green = '#3fb950';
const red = '#f85149';
const purple = '#a371f7';
const teal = '#58a6ff';
const gold = '#d29922';
const muted = '#8b949e';
const border = '#30363d';

Chart.defaults.color = muted;
Chart.defaults.borderColor = border;
Chart.defaults.font.family = "'Space Grotesk', sans-serif";

function showPage(id, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
}

// Overview — Returns Bar Chart
new Chart(document.getElementById('returnsChart'), {
  type:'bar',
  data:{
    labels:['Cycle 1: +9,213%','Cycle 2: +2,960%','Cycle 3: +680%','Cycle 4: +98%'],
    datasets:[{
      label:'Post-Halving Return to ATH',
      data:[9213,2960,680,98],
      backgroundColor:[
        'rgba(247,147,26,0.9)','rgba(247,147,26,0.7)',
        'rgba(247,147,26,0.5)','rgba(247,147,26,0.35)'
      ],
      borderColor:btcOrange,
      borderWidth:1,
      borderRadius:4,
    }]
  },
  options:{
    responsive:true, indexAxis:'y',
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>` +${c.raw.toLocaleString()}%`}}},
    scales:{
      x:{grid:{color:border},ticks:{callback:v=>v.toLocaleString()+'%'}},
      y:{grid:{display:false}}
    }
  }
});

// Drawdown Bar
new Chart(document.getElementById('drawdownChart'), {
  type:'bar',
  data:{
    labels:['Cycle 1\n2013-2015','Cycle 2\n2017-2018','Cycle 3\n2021-2022','Cycle 4\n2025-?'],
    datasets:[{
      data:[85.2,84.3,77.5,46.7],
      backgroundColor:['rgba(248,81,73,0.8)','rgba(248,81,73,0.65)','rgba(248,81,73,0.5)','rgba(248,81,73,0.35)'],
      borderColor:red, borderWidth:1, borderRadius:4
    }]
  },
  options:{
    responsive:true,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`−${c.raw}%`}}},
    scales:{
      x:{grid:{display:false}},
      y:{grid:{color:border},ticks:{callback:v=>'-'+v+'%'},suggestedMax:100}
    }
  }
});

// Days to ATH
new Chart(document.getElementById('daysChart'), {
  type:'bar',
  data:{
    labels:['Cycle 1','Cycle 2','Cycle 3','Cycle 4'],
    datasets:[{
      data:[367,525,546,534],
      backgroundColor:[teal,teal,teal,btcOrange],
      borderColor:[teal,teal,teal,btcOrange],
      borderWidth:1, borderRadius:4
    }]
  },
  options:{
    responsive:true,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.raw} days`}}},
    scales:{
      x:{grid:{display:false}},
      y:{grid:{color:border},ticks:{callback:v=>v+'d'},suggestedMin:300,suggestedMax:600}
    }
  }
});

// Post-Halving performance line
new Chart(document.getElementById('postHalvingChart'), {
  type:'line',
  data:{
    labels:['Day 0','Day 60','Day 120','Day 180','Day 240','Day 300','Day 365'],
    datasets:[
      {label:'Cycle 1 (2012)',data:[100,108,225,790,1250,4200,7960],borderColor:'rgba(247,147,26,0.9)',tension:.4,fill:false,pointRadius:2},
      {label:'Cycle 2 (2016)',data:[100,104,108,120,190,380,490],borderColor:teal,tension:.4,fill:false,pointRadius:2},
      {label:'Cycle 3 (2020)',data:[100,112,130,145,195,345,635],borderColor:green,tension:.4,fill:false,pointRadius:2},
      {label:'Cycle 4 (2024)',data:[100,90,97,102,108,140,152],borderColor:purple,tension:.4,fill:false,pointRadius:2},
    ]
  },
  options:{
    responsive:true,
    plugins:{legend:{position:'top',labels:{boxWidth:12}}},
    scales:{
      x:{grid:{color:border}},
      y:{grid:{color:border},ticks:{callback:v=>v+'x indexed'}}
    }
  }
});

// Bull duration
new Chart(document.getElementById('bullDurationChart'), {
  type:'bar',
  data:{
    labels:['Cycle 1','Cycle 2','Cycle 3','Cycle 4'],
    datasets:[{
      label:'Bull Run Days',
      data:[367,525,546,534],
      backgroundColor:'rgba(63,185,80,0.6)',
      borderColor:green, borderWidth:1, borderRadius:4
    }]
  },
  options:{
    responsive:true,
    plugins:{legend:{display:false}},
    scales:{
      x:{grid:{display:false}},
      y:{grid:{color:border},ticks:{callback:v=>v+'d'}}
    }
  }
});

// Bear duration
new Chart(document.getElementById('bearDurationChart'), {
  type:'bar',
  data:{
    labels:['Cycle 1','Cycle 2','Cycle 3','Cycle 4*'],
    datasets:[{
      label:'Bear Duration',
      data:[409,363,376,146],
      backgroundColor:['rgba(248,81,73,0.7)','rgba(248,81,73,0.7)','rgba(248,81,73,0.7)','rgba(248,81,73,0.3)'],
      borderColor:red, borderWidth:1, borderRadius:4
    }]
  },
  options:{
    responsive:true,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.raw+(c.dataIndex===3?' days (ongoing)':' days')}}},
    scales:{
      x:{grid:{display:false}},
      y:{grid:{color:border},ticks:{callback:v=>v+'d'}}
    }
  }
});

// Bear severity
new Chart(document.getElementById('bearSeverityChart'), {
  type:'line',
  data:{
    labels:['2011','Cycle 1\n(2013-15)','Cycle 2\n(2017-18)','Cycle 3\n(2021-22)','Cycle 4\n(projected)'],
    datasets:[{
      label:'Max Drawdown %',
      data:[93,85.2,84.3,77.5,73],
      borderColor:red, backgroundColor:'rgba(248,81,73,0.1)',
      tension:.4, fill:true, pointRadius:5,
      pointBackgroundColor:[red,red,red,red,'rgba(248,81,73,0.4)']
    }]
  },
  options:{
    responsive:true,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`−${c.raw}%`}}},
    scales:{
      x:{grid:{color:border}},
      y:{grid:{color:border},reverse:true,ticks:{callback:v=>'-'+v+'%'},min:60,max:100}
    }
  }
});

// Projection chart
new Chart(document.getElementById('projectionChart'), {
  type:'bar',
  data:{
    labels:['−50%\n$63,148','−65%\n$44,204','−70%\n$37,889','−73%\n$34,100','−76%\n$30,311'],
    datasets:[{
      data:[63148,44204,37889,34100,30311],
      backgroundColor:['rgba(248,81,73,0.3)','rgba(248,81,73,0.45)','rgba(248,81,73,0.6)','rgba(248,81,73,0.75)','rgba(248,81,73,0.9)'],
      borderColor:red, borderWidth:1, borderRadius:4
    }]
  },
  options:{
    responsive:true,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>'$'+c.raw.toLocaleString()}}},
    scales:{
      x:{grid:{display:false}},
      y:{grid:{color:border},ticks:{callback:v=>'$'+v.toLocaleString()}}
    }
  }
});

// Dominance chart
new Chart(document.getElementById('dominanceChart'), {
  type:'line',
  data:{
    labels:['Bear Bottom','Early Bull','Pre-ATH','ATH','Post-ATH Bear','Recovery'],
    datasets:[
      {label:'Cycle 2 (2017)',data:[86,72,65,38,55,62],borderColor:teal,tension:.4,fill:false,pointRadius:3},
      {label:'Cycle 3 (2021)',data:[70,63,55,38,60,55],borderColor:green,tension:.4,fill:false,pointRadius:3},
      {label:'Cycle 4 (2024+)',data:[55,55,55,56,59,null],borderColor:btcOrange,tension:.4,fill:false,pointRadius:3,
       borderDash:[5,5]},
    ]
  },
  options:{
    responsive:true,
    plugins:{legend:{position:'top',labels:{boxWidth:12}},tooltip:{callbacks:{label:c=>c.raw+'% dominance'}}},
    scales:{
      x:{grid:{color:border}},
      y:{grid:{color:border},ticks:{callback:v=>v+'%'},min:30,max:90}
    }
  }
});
</script>
</body>
</html>
